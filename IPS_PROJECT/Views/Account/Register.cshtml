@model IPS_PROJECT.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    ViewData["PageCss"] = "style.css"; // ملف CSS الخاص بالتسجيل
}




<form asp-action="Register" method="post">
<div class="login-container">

    <!-- Header -->
    <div class="header">
        <i class="fas fa-shield-alt logo-icon"></i>
        <div class="logo-text">
            <h2>AI-Based IPS</h2>
            <p>Intrusion Prevention System</p>
        </div>
    </div>

    <!-- Card -->
    <div class="card">
        <h1>Create Account</h1>

        <!-- Full Name -->
        <div class="input-group">
            <label>Full Name</label>
            <div class="input-wrapper">
                    <input asp-for="FullName" placeholder="Enter your full name" id="nameInput">
                <i class="fas fa-check-circle check-icon"></i>
            </div>
        </div>

        <!-- Email -->
        <div class="input-group">
            <label>Email Address</label>
            <div class="input-wrapper">
                   <input asp-for="Email" placeholder="Enter your email" id="emailInput">
                <i class="fas fa-check-circle check-icon"></i>
            </div>
        </div>

        <!-- Password -->
        <div class="input-group">
            <label>Password</label>
            <div class="input-wrapper">
                    <input asp-for="Password" type="password" placeholder="Create a password" id="passwordInput">
                <i class="fas fa-eye toggle-password" id="togglePassword"></i>
            </div>
        </div>

        <!-- Confirm Password -->
        <div class="input-group">
            <label>Confirm Password</label>
            <div class="input-wrapper">
                    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your password" id="confirmPassword">
                <i class="fas fa-eye toggle-password" id="toggleConfirmPassword"></i>
            </div>
        </div>

        <!-- Sign Up Button -->
            <button type="submit" class="main-btn user-btn" id="signUpBtn">
            <span>Create Account</span>
            <i class="fas fa-user-plus"></i>
        </button>

        </div>
    </div>

    @Html.AntiForgeryToken()

    <p class="signup-text">

        <a asp-action="Login">Already have an account? Login</a>

    </p>

</form>


        <!-- Back to Login -->
       

 


@foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
{
    <p style="color:red">@error.ErrorMessage</p>
}